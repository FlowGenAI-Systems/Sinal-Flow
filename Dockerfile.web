# Sinal — Serviço Web (frontend React/Vite)
FROM node:24
WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10.4.1 --activate

COPY . .
RUN pnpm install

RUN PORT=8080 BASE_PATH=/ NODE_ENV=production pnpm --filter @workspace/sinal-web run build

ENV NODE_ENV=production
ENV PORT=8080
ENV BASE_PATH=/
EXPOSE 8080
# Servidor próprio: serve o front E repassa /api para a API
CMD ["node", "artifacts/sinal-web/serve.mjs"]
